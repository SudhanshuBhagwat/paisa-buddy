{
  "name": "@paisa-buddy/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:tunnel": "expo start --dev-client --tunnel",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:all": "eas build --profile development --platform all",
    "build": "expo export",
    "type-check": "tsc --noEmit",
    "lint": "expo lint",
    "clean": "rm -rf .expo dist"
  },
  "dependencies": {
    "@paisa-buddy/types": "workspace:*",
    "@paisa-buddy/ui": "workspace:*",
    "@paisa-buddy/utils": "workspace:*",
    "expo": "~52.0.28",
    "expo-dev-client": "~4.0.25",
    "expo-font": "~13.0.2",
    "expo-linking": "~7.0.4",
    "expo-router": "~4.0.17",
    "expo-splash-screen": "~0.29.18",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "^5.3.3"
  }
}
